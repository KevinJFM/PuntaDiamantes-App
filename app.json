{
  "expo": {
    "name": "Punta Diamantes",
    "slug": "puntadiamantes-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-pd.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puntadiamantes.app"
    },
    "android": {
      "package": "com.puntadiamantes.app",
      "adaptiveIcon": {
        "backgroundColor": "#E5388A",
        "foregroundImage": "./assets/adaptive-pd.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#E5388A"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7db55005-75dd-476a-9cf5-9c12b82cfcf8"
      }
    },
    "owner": "kevinjavier"
  }
}
